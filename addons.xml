<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.dragonmax" name="DragonMax Repository" version="1.6.1" provider-name="DragonMax RD">
    <extension point="xbmc.addon.repository" name="DragonMax Repository">
        <info compressed="false">https://acarranza420-ui.github.io/DragonMax2/addons.xml</info>
        <checksum>https://acarranza420-ui.github.io/DragonMax2/addons.xml.md5</checksum>
        <datadir zip="true">https://acarranza420-ui.github.io/DragonMax2/</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">DragonMax RD legal Kodi repository</summary>
        <description lang="en_GB">Repository for the DragonMax RD Wizard and legal DragonMax RD build assets.</description>
        <disclaimer lang="en_GB">Use only with content and services you are authorized to access.</disclaimer>
        <platform>all</platform>
        <assets><icon>icon.png</icon><fanart>fanart.jpg</fanart></assets>
    </extension>
</addon>
<addon id="plugin.program.dragonmaxwizard" name="DragonMax RD Wizard" version="1.6.1" provider-name="DragonMax RD">
    <requires><import addon="xbmc.python" version="3.0.0"/></requires>
    <extension point="xbmc.python.pluginsource" library="default.py"><provides>executable</provides></extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">DragonMax RD Wizard</summary>
        <description lang="en_GB">Legal setup wizard for DragonMax RD themes, guides, maintenance notes, and configuration help.</description>
        <platform>all</platform>
        <assets><icon>icon.png</icon><fanart>fanart.jpg</fanart></assets>
    </extension>
</addon>
</addons>
