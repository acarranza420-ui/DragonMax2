<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.dragonmax" name="DragonMax RD Repository" version="1.6.0" provider-name="DragonMax RD">
  <extension point="xbmc.addon.repository" name="DragonMax RD Repository">
    <dir>
      <info compressed="false">https://acarranza420-ui.github.io/DragonMax-RD-Ultimate/addons.xml</info>
      <checksum>https://acarranza420-ui.github.io/DragonMax-RD-Ultimate/addons.xml.md5</checksum>
      <datadir zip="true">https://acarranza420-ui.github.io/DragonMax-RD-Ultimate/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">DragonMax RD legal Kodi repository</summary>
    <description lang="en_US">Repository for DragonMax RD Wizard v6.0, a legal theme/setup wizard starter for Kodi 21 Omega.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>
<addon id="plugin.program.dragonmaxwizard" name="DragonMax RD Wizard" version="1.6.0" provider-name="DragonMax RD">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_US">DragonMax RD v6 legal build wizard</summary>
    <description lang="en_US">An original DragonMax setup wizard for legal themes, Netflix-style layout, realms, concierge, office panel shortcuts, service sign-in guidance, audio theater setup, maintenance, QR media upload, voice settings, and Fire Stick optimization. No piracy add-ons or unauthorized content access are included.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>
</addons>
